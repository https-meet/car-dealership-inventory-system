{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",

    "rootDir": "./",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "types": ["node", "jest"],

    "sourceMap": true,

    "skipLibCheck": true
  },

  "include": [
    "src",
    "tests"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}